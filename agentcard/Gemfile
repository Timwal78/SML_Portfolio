source "https://rubygems.org"

# ---------------------------------------------------------------------------
# Framework
# ---------------------------------------------------------------------------
gem "rails", "~> 7.2.3", ">= 7.2.3.1"

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
gem "pg", "~> 1.1"

# ---------------------------------------------------------------------------
# Web server
# ---------------------------------------------------------------------------
gem "puma", ">= 5.0"

# ---------------------------------------------------------------------------
# Background jobs
# ---------------------------------------------------------------------------
gem "redis", ">= 4.0.1"
gem "sidekiq", "~> 7.0"
gem "sidekiq-scheduler", "~> 5.0"

# ---------------------------------------------------------------------------
# Cryptography & field-level encryption
# ---------------------------------------------------------------------------
gem "rbnacl", "~> 7.1"       # Ed25519 signing / NaCl primitives
gem "lockbox", "~> 1.3"       # Transparent AES-256-GCM column encryption
gem "blind_index", "~> 2.3"   # HMAC-indexed search over encrypted fields

# ---------------------------------------------------------------------------
# Search
# ---------------------------------------------------------------------------
gem "pg_search", "~> 2.3"     # PostgreSQL full-text and trigram search

# ---------------------------------------------------------------------------
# Security & rate limiting
# ---------------------------------------------------------------------------
gem "rack-attack", "~> 6.7"

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
gem "rack-cors", "~> 2.0"

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
gem "jwt", "~> 2.8"
gem "bcrypt", "~> 3.1.7"

# ---------------------------------------------------------------------------
# Serialization
# ---------------------------------------------------------------------------
gem "active_model_serializers", "~> 0.10"

# ---------------------------------------------------------------------------
# JSON Schema validation
# ---------------------------------------------------------------------------
gem "json-schema", "~> 4.0"

# ---------------------------------------------------------------------------
# File uploads & Active Storage
# ---------------------------------------------------------------------------
gem "image_processing", "~> 1.2"
gem "aws-sdk-s3", "~> 1.0", require: false

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
gem "premailer-rails", "~> 1.12"   # Inline CSS for HTML emails

# ---------------------------------------------------------------------------
# SEO / meta tags (profile pages: /a/:slug, /discover, /leaderboard)
# ---------------------------------------------------------------------------
gem "meta-tags", "~> 2.21"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
gem "lograge", "~> 0.14"

# ---------------------------------------------------------------------------
# Boot performance
# ---------------------------------------------------------------------------
# Reduces boot times through caching; required in config/boot.rb
gem "bootsnap", require: false

# Windows does not include zoneinfo files, so bundle the tzinfo-data gem
gem "tzinfo-data", platforms: %i[windows jruby]

# ---------------------------------------------------------------------------
# Development & Test
# ---------------------------------------------------------------------------
group :development, :test do
  # Debugging
  gem "debug", platforms: %i[mri windows], require: "debug/prelude"

  # Test framework
  gem "rspec-rails", "~> 6.1"
  gem "factory_bot_rails", "~> 6.4"
  gem "faker", "~> 3.2"
  gem "shoulda-matchers", "~> 6.0"
  gem "database_cleaner-active_record", "~> 2.1"

  # CI test reporting
  gem "rspec_junit_formatter", "~> 0.6"

  # Static analysis
  gem "brakeman", require: false
  gem "rubocop-rails-omakase", require: false
end
