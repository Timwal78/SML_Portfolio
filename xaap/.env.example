# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# x402 Payment
MERCHANT_WALLET_ADDRESS=          # Your USDC wallet on Base
X402_FACILITATOR_URL=https://x402.org/facilitator

# Smart Contracts (Base mainnet)
XAAP_CORE_ADDRESS=
XAAP_REPUTATION_ADDRESS=
XAAP_TREASURY_ADDRESS=
XAAP_AGENT_REWARDS_ADDRESS=
XAAP_LOYALTY_ADDRESS=

# EDGAR (no auth required)
