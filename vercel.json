      "permanent": false
    },
    {
      "source": "/stack/402proof",
      "destination": "https://four02proof.onrender.com/",
      "permanent": false
    },
    {
      "source": "/stack/squeezeos",
      "destination": "https://squeezeos-api.onrender.com/health",
      "permanent": false
    },
    {
      "source": "/stack/ghost",
      "destination": "/stack.html",
      "permanent": false
    },
    {
      "source": "/stack/zeroquery",
      "destination": "/stack.html",
      "permanent": false
    },
    {
      "source": "/stack/xahpay",
      "destination": "/stack.html",
      "permanent": false
    },
    {
      "source": "/stack/xah_portal",
      "destination": "/stack.html",
      "permanent": false
    },
    {
      "source": "/store",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/apps/exo-brain",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/neurospark",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/enoch-adhd",
      "destination": "/books.html",
      "permanent": true
    },
    {
      "source": "/NeuroStack",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/MasterSheets",
      "destination": "/smlsheets.html",
      "permanent": true
    },
    {
      "source": "/apps/fee-forge",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/trading-indicators",
      "destination": "/indicators.html",
      "permanent": true
    },
    {
      "source": "/books/book-of-enoch",
      "destination": "/books.html",
      "permanent": true
    },
    {
      "source": "/mastersheets.html",
      "destination": "/smlsheets.html",
      "permanent": true
    },
    {
      "source": "/mastersheets",
      "destination": "/smlsheets.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://pagead2.googlesyndication.com https://www.google-analytics.com https://googleads.g.doubleclick.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https: blob:; connect-src 'self' https://sml-nlweb.onrender.com https://www.google-analytics.com https://analytics.google.com https://stats.g.doubleclick.net https://pagead2.googlesyndication.com; frame-src https://googleads.g.doubleclick.net https://tpc.googlesyndication.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self' mailto:"
        }
      ]
    },
    {
      "source": "/agents.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/.well-known/security.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "cleanUrls": false,
  "trailingSlash": false
}
