{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "scriptmasterlabs.com"
        }
      ],
      "destination": "https://www.scriptmasterlabs.com/:path*",
      "permanent": true
    },
    {
      "source": "/stack",
      "destination": "/stack.html",
      "permanent": false
    },
    {
      "source": "/affiliate",
      "destination": "/affiliate.html",
      "permanent": false
    },
    {
      "source": "/stack/nexus-402",
