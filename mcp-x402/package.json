{
  "name": "@scriptmasterlabs/mcp-x402",
  "version": "2.0.0",
  "description": "The Amazon for all things payrail. 43 MCP tools across institutional trading intelligence, SEC data, XRPL/Base/Solana payments, agent commerce, and sovereign Web3 infrastructure — all gated by x402 micropayments.",
  "main": "dist/server/index.js",
  "types": "dist/server/index.d.ts",
  "bin": {
    "mcp-x402": "dist/server/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "start:sse": "MCP_TRANSPORT=sse node dist/server/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x402",
    "ai-agents",
    "autonomous-payments",
    "scriptmasterlabs",
    "xrpl",
    "base",
    "solana",
    "stablecoins",
    "rlusd",
    "usdc"
  ],
  "author": "ScriptMasterLabs <timothy.walton45@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/timwal78/sml_portfolio.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8",
    "viem": "^2.21.0",
    "xrpl": "^4.1.0",
    "@solana/web3.js": "^1.95.5",
    "@solana/spl-token": "^0.4.9",
    "keytar": "^7.9.0",
    "node-forge": "^1.3.1",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "bip39": "^3.1.0",
    "hdkey": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/node-forge": "^1.3.11",
    "@types/hdkey": "^2.0.5",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "sdk/mcp-x402-sdk"
  ]
}
