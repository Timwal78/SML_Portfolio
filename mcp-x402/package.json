{
  "name": "@scriptmasterlabs/mcp-x402",
  "version": "2.1.2",
  "mcpName": "io.github.Timwal78/mcp-x402",
  "description": "The first MCP server that pays for itself. AI agents pay for ScriptMasterLabs data autonomously via x402.",
  "main": "dist/server/index.js",
  "types": "dist/server/index.d.ts",
  "bin": {
    "mcp-x402": "dist/server/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "start:sse": "MCP_TRANSPORT=sse node dist/server/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "pay-standard": "node scripts/pay-standard.mjs",
    "acp-self-test-buyer": "tsx scripts/acp-self-test-buyer.ts",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x402",
    "ai-agents",
    "autonomous-payments",
    "scriptmasterlabs",
    "xrpl",
    "base",
    "solana",
    "stablecoins",
    "rlusd",
    "usdc"
  ],
  "author": "ScriptMasterLabs <timothy.walton45@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/timwal78/sml_portfolio.git"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.51.2",
    "@coinbase/x402": "^2.1.0",
    "@x402/core": "^2.17.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@virtuals-protocol/acp-node-v2": "^0.1.6",
    "@account-kit/infra": "^4.88.4",
    "zod": "^3.23.8",
    "viem": "^2.21.0",
    "xrpl": "^4.1.0",
    "@solana/web3.js": "^1.95.5",
    "@solana/spl-token": "^0.4.9",
    "keytar": "^7.9.0",
    "node-forge": "^1.3.1",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "bip39": "^3.1.0",
    "hdkey": "^2.1.0",
    "stripe": "^17.4.0",
    "@aws-sdk/client-marketplace-metering": "^3.700.0",
    "@aws-sdk/client-marketplace-entitlement-service": "^3.700.0",
